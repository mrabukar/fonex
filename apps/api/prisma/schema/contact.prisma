model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String
  interest  String
  message   String
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([productId])
}
